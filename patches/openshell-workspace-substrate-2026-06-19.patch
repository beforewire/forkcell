+    assert_eq!(workspace["type"], "forkcell_overlay");
+    assert_eq!(workspace["volume"], "forkcell-work-cellid");
+    assert_eq!(workspace["target"], "/sandbox/work");
+    assert_eq!(workspace["backing_path"], WORKSPACE_BACKING_MOUNT_PATH);
+    assert_eq!(workspace["checkpoint_id"], "chk_123");
